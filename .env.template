# Ansible Portal Installer Environment Configuration Template
# Copy this file to .env and fill in your values
# The installer will automatically load variables from .env file

# ==============================================================================
# OPENSHIFT CLUSTER CONFIGURATION
# ==============================================================================

# OpenShift cluster API URL (optional - will use current context if not set)
# Example: https://api.cluster-abc123.abc123.example.openshiftapps.com:6443
# OCP_CLUSTER_URL=

# OpenShift namespace/project for deployment (REQUIRED)
# Example: ansible-portal-dev
OCP_NAMESPACE=

# ==============================================================================
# DEPLOYMENT CONFIGURATION
# ==============================================================================

# Deployment backend (default: helm)
# Options: helm, operator, rhel
# DEPLOYMENT_BACKEND=helm

# Helm release name (default: rhaap-portal-dev)
# This becomes part of the pod name and route
# RELEASE_NAME=rhaap-portal-dev

# Path to ansible-portal-chart repository (default: ../ansible-portal-chart)
# Must be absolute or relative to current directory
# CHART_PATH=../ansible-portal-chart

# Path to ansible-rhdh-plugins repository (default: .)
# This repo contains build.sh and should have ansible-backstage-plugins symlinked
# PLUGINS_PATH=.

# ==============================================================================
# AAP (ANSIBLE AUTOMATION PLATFORM) CONFIGURATION
# ==============================================================================

# AAP Controller URL (REQUIRED)
# Must start with https:// or http://
# Example: https://aap.example.com
AAP_HOST_URL=

# AAP API Token (REQUIRED)
# Create at: AAP Controller → User Profile → Tokens → Add
# Scope: Read + Write
# Note: This token is shown only once when created
AAP_TOKEN=

# AAP OAuth Client ID (REQUIRED)
# Create at: AAP Controller → Administration → OAuth Applications → Add
# Grant Type: Authorization code, Client Type: Confidential
# Note: You'll need to update redirect URIs after deployment
OAUTH_CLIENT_ID=

# AAP OAuth Client Secret (REQUIRED)
# This is shown when you create the OAuth application
OAUTH_CLIENT_SECRET=

# ==============================================================================
# GITHUB CONFIGURATION (OPTIONAL)
# ==============================================================================

# GitHub Personal Access Token (for content discovery and Git operations)
# Create at: GitHub → Settings → Developer settings → Personal access tokens → Tokens (classic)
# Scopes: repo, read:org, user:email
# GITHUB_TOKEN=

# GitHub OAuth Client ID (for GitHub sign-in)
# Create at: GitHub → Settings → Developer settings → OAuth Apps → New OAuth App
# You'll need to update the callback URL after deployment
# GITHUB_CLIENT_ID=

# GitHub OAuth Client Secret
# Generated when you create the GitHub OAuth app
# GITHUB_CLIENT_SECRET=

# ==============================================================================
# GITLAB CONFIGURATION (OPTIONAL)
# ==============================================================================

# GitLab Personal Access Token (for content discovery and Git operations)
# GITLAB_TOKEN=

# GitLab OAuth Client ID (for GitLab sign-in)
# GITLAB_CLIENT_ID=

# GitLab OAuth Client Secret
# GITLAB_CLIENT_SECRET=

# ==============================================================================
# CONTAINER REGISTRY CONFIGURATION
# ==============================================================================

# Plugin container registry URL (optional - will auto-detect OpenShift internal registry)
# For OpenShift internal registry: Leave blank (auto-detected)
# For external registry: quay.io/YOUR_USERNAME or registry.example.com/your-org
# Note: Do not include the image name, just the registry/namespace
# Example: quay.io/myuser
# PLUGIN_REGISTRY=

# Plugin image tag (default: dev)
# Used for versioning your plugin builds
# Example: dev-20260430, v1.0.0, latest
PLUGIN_IMAGE_TAG=dev

# ==============================================================================
# PORTAL ADMIN CONFIGURATION
# ==============================================================================

# Portal admin password (optional - will be auto-generated if not set)
# This is the password for the built-in admin user
# The generated password will be displayed after deployment
# PORTAL_ADMIN_PASSWORD=

# ==============================================================================
# SSL/TLS CONFIGURATION
# ==============================================================================

# Enable SSL verification for AAP connections (default: false for dev)
# Set to true for production environments with valid certificates
# Options: true, false
# CHECK_SSL=false

# Configure insecure registry support for OpenShift internal registry (default: true)
# This creates a registries.conf ConfigMap to skip TLS verification
# Set to false if using external registry with valid certificates
# Options: true, false
INSECURE_REGISTRY=true

# ==============================================================================
# BUILD AND DEPLOYMENT FLAGS
# ==============================================================================

# Skip plugin build step (default: false)
# Set to true to reuse existing plugin image (must specify PLUGIN_REGISTRY)
# Useful for testing Helm changes without rebuilding plugins
# SKIP_PLUGIN_BUILD=false

# Skip waiting for rollout after Helm deployment (default: false)
# Set to true to return immediately after helm install (useful for debugging slow pods)
# You can manually check status with: kubectl rollout status deployment/<release>
# SKIP_ROLLOUT_WAIT=false

# Rollout timeout (default: 40m)
# How long to wait for deployment to be ready
# RHDH + OCI plugin init can take 30-40 minutes
# Examples: 30m, 1h, 60m
ROLLOUT_TIMEOUT=40m

# Verbose output (default: false)
# Set to true for more detailed logging
# VERBOSE=false

# ==============================================================================
# QUICK START EXAMPLES
# ==============================================================================

# Example 1: Minimal Dev Setup (OpenShift internal registry, auto-generated admin password)
# OCP_NAMESPACE=my-portal-dev
# AAP_HOST_URL=https://aap.dev.example.com
# AAP_TOKEN=your-aap-token-here
# OAUTH_CLIENT_ID=your-oauth-client-id
# OAUTH_CLIENT_SECRET=your-oauth-client-secret

# Example 2: With GitHub Integration
# OCP_NAMESPACE=my-portal-dev
# AAP_HOST_URL=https://aap.dev.example.com
# AAP_TOKEN=your-aap-token-here
# OAUTH_CLIENT_ID=your-oauth-client-id
# OAUTH_CLIENT_SECRET=your-oauth-client-secret
# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
# GITHUB_CLIENT_ID=your-github-client-id
# GITHUB_CLIENT_SECRET=your-github-client-secret

# Example 3: External Registry (Quay.io)
# OCP_NAMESPACE=my-portal-dev
# AAP_HOST_URL=https://aap.dev.example.com
# AAP_TOKEN=your-aap-token-here
# OAUTH_CLIENT_ID=your-oauth-client-id
# OAUTH_CLIENT_SECRET=your-oauth-client-secret
# PLUGIN_REGISTRY=quay.io/myusername
# PLUGIN_IMAGE_TAG=v1.0.0
# INSECURE_REGISTRY=false  # Quay has valid certs

# Example 4: Production Setup
# OCP_NAMESPACE=ansible-portal-prod
# RELEASE_NAME=ansible-portal
# AAP_HOST_URL=https://aap.prod.example.com
# AAP_TOKEN=your-aap-token-here
# OAUTH_CLIENT_ID=your-oauth-client-id
# OAUTH_CLIENT_SECRET=your-oauth-client-secret
# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
# GITHUB_CLIENT_ID=your-github-client-id
# GITHUB_CLIENT_SECRET=your-github-client-secret
# PORTAL_ADMIN_PASSWORD=your-secure-password-here
# PLUGIN_IMAGE_TAG=v2.1.0
# CHECK_SSL=true
# INSECURE_REGISTRY=false
# ROLLOUT_TIMEOUT=60m

# ==============================================================================
# USAGE NOTES
# ==============================================================================

# 1. Copy this file to .env:
#    cp .env.template .env
#
# 2. Fill in at minimum:
#    - OCP_NAMESPACE
#    - AAP_HOST_URL
#    - AAP_TOKEN
#    - OAUTH_CLIENT_ID
#    - OAUTH_CLIENT_SECRET
#
# 3. Deploy:
#    ansible-portal-installer deploy
#    (The installer will automatically load .env file)
#
# 4. Or use command-line flags to override .env:
#    ansible-portal-installer deploy --namespace override-namespace
#
# 5. Preview generated values without deploying:
#    ansible-portal-installer deploy --dry-run
#
# 6. Export generated values to file:
#    ansible-portal-installer deploy --values-output my-values.yaml

# ==============================================================================
# SECURITY NOTES
# ==============================================================================

# WARNING: This file contains sensitive credentials!
# - Add .env to .gitignore (already done)
# - Never commit .env to version control
# - Use secure storage for production credentials (Vault, Secrets Manager, etc.)
# - Rotate tokens and secrets regularly
# - Use environment-specific .env files (.env.dev, .env.prod)

# ==============================================================================
# TROUBLESHOOTING
# ==============================================================================

# If deployment fails:
#
# 1. Verify OAuth applications are created:
#    ansible-portal-installer deploy  # Will show setup guide if creds missing
#
# 2. Check cluster connectivity:
#    oc whoami  # Should show your username
#    oc project  # Should show current namespace
#
# 3. Preview what would be deployed:
#    ansible-portal-installer deploy --dry-run
#
# 4. Check for missing/invalid variables:
#    The installer validates all required fields and shows clear errors
#
# 5. Enable verbose logging:
#    VERBOSE=true ansible-portal-installer deploy

# ==============================================================================
# OAUTH REDIRECT URI UPDATE (POST-DEPLOYMENT)
# ==============================================================================

# CRITICAL: After deployment, you MUST update your OAuth application redirect URIs
# with the actual portal route. The installer will print the exact URLs you need.
#
# Example output:
#   Portal URL: https://rhaap-portal-dev-my-portal.apps.cluster.example.com
#
#   Update AAP OAuth app redirect URIs to:
#     • https://rhaap-portal-dev-my-portal.apps.cluster.example.com/api/auth/rhaap/handler/frame
#     • https://rhaap-portal-dev-my-portal.apps.cluster.example.com/api/auth/github/handler/frame
#
#   Update GitHub OAuth app callback URL to:
#     • https://rhaap-portal-dev-my-portal.apps.cluster.example.com/api/auth/github/handler/frame
#
# Without this step, authentication will fail with redirect_uri_mismatch errors.
