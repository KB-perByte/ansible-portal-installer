# Ansible Portal Installer - Quick Start Configuration
# Copy to .env and fill in your values: cp .env.example .env

# ==============================================================================
# REQUIRED: OpenShift & Namespace
# ==============================================================================
OCP_NAMESPACE=

# ==============================================================================
# REQUIRED: AAP (Ansible Automation Platform) Credentials
# ==============================================================================
# AAP Controller URL (must start with https:// or http://)
AAP_HOST_URL=

# AAP API Token (from User Profile → Tokens)
AAP_TOKEN=

# AAP OAuth Client ID (from Administration → OAuth Applications)
OAUTH_CLIENT_ID=

# AAP OAuth Client Secret (from OAuth Application)
OAUTH_CLIENT_SECRET=

# ==============================================================================
# OPTIONAL: GitHub Integration
# ==============================================================================
# GITHUB_TOKEN=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# ==============================================================================
# OPTIONAL: Advanced Configuration
# ==============================================================================
# RELEASE_NAME=rhaap-portal-dev
# CHART_PATH=../ansible-portal-chart
# PLUGINS_PATH=.
# PLUGIN_REGISTRY=  # Leave blank for OpenShift internal registry
# PLUGIN_IMAGE_TAG=dev
# PORTAL_ADMIN_PASSWORD=  # Auto-generated if not set
# INSECURE_REGISTRY=true
# ROLLOUT_TIMEOUT=40m

# ==============================================================================
# USAGE
# ==============================================================================
# 1. Fill in the REQUIRED fields above
# 2. Run: ansible-portal-installer deploy
# 3. Update OAuth redirect URIs with URLs printed after deployment
# 4. Verify deployment with checklist printed by installer

# See .env.template for full documentation and examples
