# Ansible Portal Installer Environment Variables
# Copy this file to .env and fill in your values

# ============================================================================
# Build Configuration
# ============================================================================

# Path to ansible-rhdh-plugins repository
ANSIBLE_RHDH_PLUGINS_PATH=/home/user/Work/ansible-portal/ansible-rhdh-plugins

# Path to ansible-backstage-plugins repository (upstream)
ANSIBLE_BACKSTAGE_PLUGINS_PATH=/home/user/Work/ansible-portal/ansible-backstage-plugins

# Build type: portal, platform, or all
BUILD_TYPE=portal

# Node version to use
NODE_VERSION=20.20.2

# ============================================================================
# Container Registry Configuration
# ============================================================================

# Container registry (quay.io, docker.io, etc.)
REGISTRY=quay.io

# Registry username/organization
REGISTRY_USERNAME=<your-username>

# Registry password/token
REGISTRY_PASSWORD=<your-password>

# Plugin image name
PLUGINS_IMAGE_NAME=ansible-portal-plugins

# Plugin image tag (default: dev-YYYYMMDD)
PLUGINS_IMAGE_TAG=dev-latest

# ============================================================================
# OpenShift/Kubernetes Configuration
# ============================================================================

# OpenShift server URL
OPENSHIFT_SERVER=https://api.example.com:6443

# OpenShift token (use 'oc whoami -t' to get current token)
OPENSHIFT_TOKEN=<your-token>

# Target namespace/project
OPENSHIFT_NAMESPACE=ansible-portal

# Skip TLS verification (true/false)
OPENSHIFT_INSECURE_SKIP_TLS_VERIFY=false

# ============================================================================
# AAP (Ansible Automation Platform) Configuration
# ============================================================================

# AAP host URL
AAP_HOST_URL=https://aap.example.com

# AAP OAuth client ID
AAP_OAUTH_CLIENT_ID=<changeme>

# AAP OAuth client secret
AAP_OAUTH_CLIENT_SECRET=<changeme>

# AAP API token
AAP_TOKEN=<changeme>

# Check SSL certificates (true/false)
AAP_CHECK_SSL=true

# ============================================================================
# GitHub Configuration
# ============================================================================

# GitHub personal access token
GITHUB_TOKEN=<changeme>

# GitHub OAuth client ID
GITHUB_CLIENT_ID=<changeme>

# GitHub OAuth client secret
GITHUB_CLIENT_SECRET=<changeme>

# GitHub organization for content discovery
GITHUB_ORG=ansible-collections

# ============================================================================
# Helm Chart Configuration
# ============================================================================

# Path to ansible-portal-chart repository
HELM_CHART_PATH=/home/user/Work/ansible-portal/ansible-portal-chart

# Helm release name
HELM_RELEASE_NAME=my-portal

# OpenShift cluster router base (e.g., apps.example.com)
CLUSTER_ROUTER_BASE=apps.example.com

# Plugin mode: oci or local
PLUGIN_MODE=oci

# Enable Ansible Git Contents discovery (true/false)
ANSIBLE_GIT_CONTENTS_ENABLED=true

# ============================================================================
# Dev Spaces Configuration (Optional)
# ============================================================================

# Dev Spaces base URL
DEV_SPACES_BASE_URL=https://devspaces.apps.example.com

# Creator service configuration
CREATOR_SERVICE_BASE_URL=localhost
CREATOR_SERVICE_PORT=5000

# ============================================================================
# Installer Behavior
# ============================================================================

# Skip confirmation prompts (true/false)
SKIP_CONFIRMATIONS=false

# Verbose output (true/false)
VERBOSE=false

# Dry run mode - show what would be done without executing (true/false)
DRY_RUN=false
